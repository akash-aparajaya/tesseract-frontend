# ───────────────────────────────
# APP CONFIG
# ───────────────────────────────

# App name
VITE_APP_NAME=Tesseract

# App version
VITE_APP_VERSION=1.0.0

# Current environment
VITE_APP_ENV=development


# ───────────────────────────────
# API CONFIG
# ───────────────────────────────

# Base API URL — your backend URL
VITE_API_URL=http://localhost:8000/api

# API timeout in milliseconds
VITE_API_TIMEOUT=10000


# ───────────────────────────────
# AUTH CONFIG
# ───────────────────────────────

# Secret key for token
VITE_JWT_SECRET=your_jwt_secret_key_here

# Token expiry time
VITE_TOKEN_EXPIRY=7d


# ───────────────────────────────
# APP PORT
# ───────────────────────────────

# Frontend port
VITE_PORT=3000